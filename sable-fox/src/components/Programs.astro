---
---
<section class="programs" id="programs">
  <div class="container">
    <div class="section-head">
      <h2>Purpose-built programs for every stage.</h2>
    </div>
    <div class="prog-grid">
      <div class="prog">
        <div class="prog-art" aria-hidden="true">
          <svg viewBox="0 0 280 280" style="width:100%;height:100%">
            <defs>
              <linearGradient id="po1" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#FF9B5C"/>
                <stop offset="100%" stop-color="#EA580C"/>
              </linearGradient>
            </defs>
            <path d="M 280 0 L 280 280 L 0 0 Z" fill="url(#po1)"/>
            <path d="M 280 60 L 280 280 L 60 60 Z" fill="#FFB37A" opacity=".6"/>
          </svg>
        </div>
        <h3>Sable Fox Foundry.</h3>
        <p>A fixed-scope hardening sprint for early-stage teams — 6 weeks to baseline security, ready for your next funding round.</p>
        <a href="/#contact" class="link">Apply now ›</a>
      </div>

      <div class="prog">
        <div class="prog-art" aria-hidden="true">
          <svg viewBox="0 0 280 280" style="width:100%;height:100%">
            <defs>
              <linearGradient id="pv1" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#C4B5FD"/>
                <stop offset="100%" stop-color="#7C3AED"/>
              </linearGradient>
            </defs>
            <path d="M 280 0 L 280 280 L 0 0 Z" fill="url(#pv1)"/>
            <path d="M 280 60 L 280 280 L 60 60 Z" fill="#F472B6" opacity=".75"/>
          </svg>
        </div>
        <h3>Den Retainer.</h3>
        <p>Always-on access to our offensive and defensive teams. Quarterly tests, monthly reviews, instant IR — one predictable invoice.</p>
        <a href="/#contact" class="link">See plans ›</a>
      </div>
    </div>
  </div>
</section>
