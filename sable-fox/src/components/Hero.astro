---
---
<section class="hero">
  <!-- Gradient ribbon background -->
  <div class="hero-ribbon" aria-hidden="true">
    <svg viewBox="0 0 1200 900" style="width:100%;height:100%" preserveAspectRatio="xMidYMid slice">
      <defs>
        <linearGradient id="r1" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#FFE2CC" stop-opacity="0"/>
          <stop offset="35%" stop-color="#FF9B5C" stop-opacity=".95"/>
          <stop offset="65%" stop-color="#EA580C" stop-opacity=".95"/>
          <stop offset="100%" stop-color="#FF6B1A" stop-opacity="0"/>
        </linearGradient>
        <linearGradient id="r2" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#FFD7B5" stop-opacity="0"/>
          <stop offset="50%" stop-color="#F472B6" stop-opacity=".75"/>
          <stop offset="100%" stop-color="#A855F7" stop-opacity="0"/>
        </linearGradient>
        <linearGradient id="r3" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#7DD3FC" stop-opacity="0"/>
          <stop offset="50%" stop-color="#A78BFA" stop-opacity=".7"/>
          <stop offset="100%" stop-color="#FB923C" stop-opacity="0"/>
        </linearGradient>
        <filter id="blur1" x="-10%" y="-10%" width="120%" height="120%">
          <feGaussianBlur stdDeviation="14"/>
        </filter>
      </defs>
      <g filter="url(#blur1)">
        <path d="M -50 200 Q 300 50 600 250 T 1300 600 L 1300 720 Q 900 520 600 400 T -50 380 Z" fill="url(#r3)"/>
        <path d="M 100 -50 Q 500 200 700 350 T 1300 700 L 1300 820 Q 900 620 700 480 T 100 100 Z" fill="url(#r2)"/>
        <path d="M 250 -50 Q 600 250 800 380 T 1300 750 L 1300 900 Q 1000 700 800 540 T 250 50 Z" fill="url(#r1)"/>
      </g>
      <g opacity=".85">
        <path d="M 400 -50 C 600 200 800 350 950 480 S 1250 720 1250 900" stroke="#FF6B1A" stroke-width="80" fill="none" stroke-linecap="round" opacity=".55"/>
        <path d="M 350 -50 C 580 230 780 360 920 500 S 1230 760 1230 900" stroke="#F472B6" stroke-width="50" fill="none" stroke-linecap="round" opacity=".5"/>
        <path d="M 480 -50 C 660 220 860 380 1000 520 S 1280 760 1280 900" stroke="#A78BFA" stroke-width="40" fill="none" stroke-linecap="round" opacity=".45"/>
      </g>
    </svg>
  </div>

  <div class="container">
    <div class="hero-grid">
      <div class="hero-meta">
        <svg width="20" height="20" viewBox="0 0 14 14" style="display:block;shape-rendering:crispEdges;flex-shrink:0">
          <rect x="3" y="0" width="1" height="1" fill="#FF6B1A"/>
          <rect x="4" y="0" width="1" height="1" fill="#FF6B1A"/>
          <rect x="9" y="0" width="1" height="1" fill="#FF6B1A"/>
          <rect x="10" y="0" width="1" height="1" fill="#FF6B1A"/>
          <rect x="3" y="1" width="1" height="1" fill="#EA580C"/>
          <rect x="4" y="1" width="1" height="1" fill="#EA580C"/>
          <rect x="9" y="1" width="1" height="1" fill="#EA580C"/>
          <rect x="10" y="1" width="1" height="1" fill="#EA580C"/>
          <rect x="3" y="2" width="6" height="6" fill="#FF6B1A"/>
          <rect x="4" y="3" width="2" height="1" fill="#0A0A14"/>
          <rect x="8" y="3" width="2" height="1" fill="#0A0A14"/>
          <rect x="6" y="6" width="2" height="1" fill="#FFFFFF"/>
        </svg>
        <span><b>Sable Fox</b> · Cyber Security Consulting</span>
        <span class="hero-status">● Operational</span>
      </div>

      <h1>
        Security that moves <span class="accent">at the speed of your business.</span>
      </h1>

      <p class="hero-sub">
        Offensive testing, defensive operations, and compliance — delivered by a team that thinks like an attacker and builds like an engineer. Sable Fox helps you find the cracks before someone else does.
      </p>

      <div class="hero-cta">
        <a href="/#contact" class="btn btn-orange">Book a discovery call <span class="chev">›</span></a>
        <a href="/#services" class="btn btn-outline">See what we do</a>
      </div>
    </div>
  </div>
</section>
