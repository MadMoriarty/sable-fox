---
const year = new Date().getFullYear();
---
<footer>
  <div class="container">
    <div class="foot-grid">
      <div class="foot-col">
        <div class="brand" style="margin-bottom:12px">
          <svg width="28" height="28" viewBox="0 0 14 14" style="display:block;shape-rendering:crispEdges">
            <rect x="3" y="0" width="1" height="1" fill="#FF6B1A"/>
            <rect x="4" y="0" width="1" height="1" fill="#FF6B1A"/>
            <rect x="9" y="0" width="1" height="1" fill="#FF6B1A"/>
            <rect x="10" y="0" width="1" height="1" fill="#FF6B1A"/>
            <rect x="3" y="1" width="1" height="1" fill="#EA580C"/>
            <rect x="4" y="1" width="1" height="1" fill="#EA580C"/>
            <rect x="9" y="1" width="1" height="1" fill="#EA580C"/>
            <rect x="10" y="1" width="1" height="1" fill="#EA580C"/>
            <rect x="3" y="2" width="6" height="6" fill="#FF6B1A"/>
            <rect x="4" y="3" width="2" height="1" fill="#0A0A14"/>
            <rect x="8" y="3" width="2" height="1" fill="#0A0A14"/>
            <rect x="6" y="6" width="2" height="1" fill="#FFFFFF"/>
            <rect x="2" y="8" width="10" height="4" fill="#FF6B1A"/>
            <rect x="3" y="12" width="2" height="1" fill="#EA580C"/>
            <rect x="9" y="12" width="2" height="1" fill="#EA580C"/>
          </svg>
          <span>Sable Fox</span>
        </div>
        <p>Cyber security consulting for teams who'd rather build than worry.</p>
      </div>

      <div class="foot-col">
        <h5>Services</h5>
        <a href="/#services">Penetration testing</a>
        <a href="/#services">Red teaming</a>
        <a href="/#services">Threat hunting</a>
        <a href="/#services">Cloud security</a>
        <a href="/#services">vCISO</a>
      </div>

      <div class="foot-col">
        <h5>Company</h5>
        <a href="/#approach">About</a>
        <a href="/blog">Field notes</a>
        <a href="/#contact">Careers</a>
        <a href="/#contact">Contact</a>
      </div>

      <div class="foot-col">
        <h5>Resources</h5>
        <a href="#">Trust center</a>
        <a href="#">Disclosure policy</a>
        <a href="#">Status</a>
        <a href="#">PGP key</a>
      </div>
    </div>

    <div class="foot-bot">
      <div>© {year} Sable Fox Security, Inc.</div>
      <div style="display:flex;gap:18px">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="#">Cookies</a>
      </div>
    </div>
  </div>
</footer>
