---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author?: string;
  tags?: string[];
  image?: string;
}

const { title, description, pubDate, author = 'Sable Fox', tags = [], image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---
<Layout title={`${title} — Sable Fox Blog`} description={description} image={image}>
  <Nav />
  <main>
    <article class="blog-post">
      <header class="blog-post-header">
        <div class="eyebrow" style="margin-bottom:12px">
          {tags.length > 0 ? tags[0] : 'Field Notes'}
        </div>
        <h1>{title}</h1>
        <div class="meta">
          <span>By {author}</span>
          <span>·</span>
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        </div>
      </header>
      <div class="blog-post-content">
        <slot />
      </div>
      <div style="max-width:720px;margin:48px auto 0;padding-top:32px;border-top:1px solid var(--line);">
        <a href="/blog" style="color:var(--orange-deep);font-weight:600;">← Back to Field Notes</a>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
