---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout
  title="Field Notes — Sable Fox"
  description="Security research, insights, and field notes from the Sable Fox team."
>
  <Nav />
  <main>
    <section class="blog">
      <div class="container">
        <div class="section-head">
          <div class="eyebrow" style="margin-bottom:12px">Field Notes</div>
          <h2>Security insights from the trenches.</h2>
          <p style="margin-top:16px;font-size:17px;color:var(--muted)">Research, case studies, and honest takes — no vendor fluff.</p>
        </div>

        {posts.length === 0 ? (
          <p style="color:var(--muted);font-size:17px">Posts coming soon. Check back shortly.</p>
        ) : (
          <div class="blog-grid">
            {posts.map(post => {
              const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric', month: 'long', day: 'numeric'
              });
              return (
                <a href={`/blog/${post.slug}`} class="blog-card" style="display:block;color:inherit">
                  <div class="blog-card-img">🦊</div>
                  <div class="blog-card-body">
                    <span class="eyebrow">{post.data.tags[0] || 'Field Notes'}</span>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                  </div>
                  <div class="blog-card-footer">
                    <span>{post.data.author}</span>
                    <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
