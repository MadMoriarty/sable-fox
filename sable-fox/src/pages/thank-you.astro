---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Message Received — Sable Fox" description="Thanks for getting in touch.">
  <Nav />
  <main>
    <div class="success-page">
      <div>
        <div style="font-size:48px;margin-bottom:16px">🦊</div>
        <h1>Message received.</h1>
        <p style="margin-top:12px">We'll be in touch within one business day.<br/>In the meantime, check out our <a href="/blog" style="color:var(--orange-deep);font-weight:600">Field Notes</a>.</p>
        <a href="/" class="btn btn-primary" style="margin-top:28px;display:inline-flex">← Back to home</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
